# Copy to cluster.local.env (gitignored) and fill in for your cluster.
# Sourced by launcher.cluster.load_cluster_env() AND by planner/cluster_env.py
# (used by hetero_4x4_*_sweep.py, cluster_setup_4x4.py, auto_sweep_robust.sh).

# REQUIRED ------------------------------------------------------------------
export HEAD_IP=127.0.0.1               # ethernet / management IP (Ray uses this only for launcher CLI)
export WORKER_IP=127.0.0.1
export HEAD_GPUS=4
export WORKER_GPUS=4
export HEAD_ACCEL=blackwell            # planner profile key (e.g. blackwell, ada, h100)
export WORKER_ACCEL=ada

# Cross-node fabric (IB / RoCE / fast network). Sweep scripts use these for
# RAY_ADDRESS, NCCL_SOCKET_IFNAME, VLLM_HOST_IP. Set to the management IPs/iface
# if you don't have a separate fabric.
export HEAD_FABRIC_IP=$HEAD_IP
export WORKER_FABRIC_IP=$WORKER_IP
export HEAD_FABRIC_IFACE=lo            # e.g. ibp3s0, eth1, ens6
export WORKER_FABRIC_IFACE=lo

# OPTIONAL ------------------------------------------------------------------
export GCS_PORT=6379
export RAY_ADDRESS=$HEAD_FABRIC_IP:$GCS_PORT
export WORKER_SSH_USER=root
export WORKER_SSH_HOST=$WORKER_IP      # the address ssh can reach the worker on
export WORKER_SSH_PORT=22

# Python interpreters. Worker may set up a symlink so the same path works on both.
export HEAD_PY=/opt/miniconda3/envs/vllm_main/bin/python
export WORKER_PY=$HEAD_PY              # symlink envs/vllm_main on worker if needed
export HEAD_RAY=/opt/miniconda3/envs/vllm_main/bin/ray
export WORKER_RAY=$HEAD_RAY

# Worker hides extra GPUs so Ray sees exactly $WORKER_GPUS — e.g. for a 4+4
# experiment on a worker physically holding 8 GPUs.
export WORKER_CUDA_VISIBLE_DEVICES=0,1,2,3

# NCCL — usually fine as-is for IB clusters.
export NCCL_IB_HCA=mlx5
export NCCL_NET_GDR_LEVEL=2

export TEMPDIR=/tmp/vllm_main_ray
