+    def _cache_metadata_from_irecv(self, tensor_dict: dict[str, torch.Tensor]) -> None:
+        """Cache (key, size, dtype, device) from a first irecv_tensor_dict call.
+
+        Stored in `self._pp_cached_metadata` so subsequent mbs can skip the
+        recv_object metadata sync. Must be invalidated if shape changes.
+        """
+        if not isinstance(tensor_dict, dict):
+            return
+        cached = []
+        for k, v in tensor_dict.items():
+            if isinstance(v, torch.Tensor):
+                cached.append((k, tuple(v.shape), v.dtype, v.device))
+            else:
+                cached.append((k, None, None, None))  # passthrough
+        self._pp_cached_metadata = cached
+
+    def _irecv_cached(self, all_gather_tensors: dict[str, bool]):
+        """Fast-path irecv using cached metadata + fresh buffers.
+
+        Bypasses `recv_object()` and the all-gather optimization (always
+        transfers the full tensor). The all-gather slicing path was tried
+        but the cached metadata couldn't disambiguate full-vs-slice shape
+        cleanly across ranks; keeping the slow-but-correct full transfer.
+        """
+        pp = get_pp_group()
+        src = (pp.rank_in_group - 1) % pp.world_size
+        src_global = pp.ranks[src]
+        tensor_dict: dict[str, Any] = {}
+        handles: list = []
+        for k, shape, dtype, device in self._pp_cached_metadata:
+            if shape is None:
+                continue
+            t = torch.empty(shape, dtype=dtype, device=device)
+            handle = torch.distributed.irecv(
+                t, src=src_global, group=pp.device_group
+            )
+            handles.append(handle)
+            tensor_dict[k] = t
+        return tensor_dict, handles, []
+
+    def _isend_cached(
+        self, tensor_dict: dict[str, torch.Tensor],
+        all_gather_tensors: dict[str, bool],
+    ):
+        """Fast-path isend bypassing send_object. Symmetric to _irecv_cached:
+        always transfers full tensors (no all-gather slicing)."""
+        pp = get_pp_group()
+        dst = (pp.rank_in_group + 1) % pp.world_size
+        dst_global = pp.ranks[dst]
+        handles: list = []
+        for k, v in tensor_dict.items():
+            if not isinstance(v, torch.Tensor) or v.numel() == 0:
+                continue
+            handle = torch.distributed.isend(
+                v, dst=dst_global, group=pp.device_group
+            )
+            if v.is_cuda:
+                v.record_stream(torch.cuda.current_stream(v.device))
+            handles.append(handle)
+        return handles
