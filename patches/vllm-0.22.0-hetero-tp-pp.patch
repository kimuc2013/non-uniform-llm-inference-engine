+    def _fast_pp_record_first_call(self, tensor_dict: dict[str, torch.Tensor]) -> None:
+        """After the first irecv_tensor_dict (or first output we sent),
+        cache per-key (dtype, device, hidden_dims) so subsequent mbs can
+        skip metadata sync. hidden_dims = shape[1:]."""
+        spec: dict[str, dict] = {}
+        keys: list[str] = []
+        for k, v in tensor_dict.items():
+            if isinstance(v, torch.Tensor):
+                spec[k] = {
+                    "dtype": v.dtype,
+                    "device": v.device,
+                    "hidden_dims": tuple(v.shape[1:]),
+                }
+                keys.append(k)
+        self._pp_fast_spec = spec
+        self._pp_fast_keys = keys
