--- a/vllm/utils/tp_split_utils.py	1970-01-01 00:00:00.000000000 +0000
+++ b/vllm/utils/tp_split_utils.py	2026-05-29 12:07:24.339463059 +0000
@@ -0,0 +1,140 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Drop-in module installed at vllm/utils/tp_split_utils.py.
+
+Reads VLLM_TP_HEAD_SPLITS / VLLM_TP_FFN_SPLITS / VLLM_TP_KV_SPLITS from
+os.environ and validates them. Used by patched model files
+(model_executor/models/llama.py, qwen3.py, opt.py).
+
+Differs from the old vllm_hetero version only in that env vars are read
+via os.environ (not vllm.envs) — so we don't have to patch envs.py too.
+"""
+from __future__ import annotations
+
+import os
+from typing import Iterable
+
+
+def _parse_int_list(raw: str) -> list[int]:
+    parts = [p.strip() for p in raw.split(",") if p.strip()]
+    if not parts:
+        raise ValueError("split string is empty")
+    try:
+        return [int(p) for p in parts]
+    except ValueError as exc:
+        raise ValueError(f"all split entries must be integers: {raw}") from exc
+
+
+def validate_splits(splits: Iterable[int], *, expected_len: int, total: int,
+                    granularity: int, name: str) -> list[int]:
+    splits = list(splits)
+    if len(splits) != expected_len:
+        raise ValueError(f"{name} length {len(splits)} != tp={expected_len}. value={splits}")
+    if any(x <= 0 for x in splits):
+        raise ValueError(f"{name} must be positive: {splits}")
+    if any(x % granularity != 0 for x in splits):
+        raise ValueError(f"{name} entries must be divisible by {granularity}: {splits}")
+    if sum(splits) != total:
+        raise ValueError(f"{name} sum {sum(splits)} != total {total}. value={splits}")
+    return splits
+
+
+def parse_and_validate_splits(raw: str, *, expected_len: int, total: int,
+                              granularity: int, name: str) -> list[int]:
+    return validate_splits(_parse_int_list(raw), expected_len=expected_len,
+                           total=total, granularity=granularity, name=name)
+
+
+def _derive_kv_splits_from_heads(*, head_splits: Iterable[int],
+                                 head_total: int, kv_total: int) -> list[int]:
+    out: list[int] = []
+    for idx, q_i in enumerate(head_splits):
+        num = int(q_i) * int(kv_total)
+        if num % int(head_total) != 0:
+            raise ValueError(
+                f"Cannot derive KV split from head split at rank {idx}: "
+                f"{q_i} * {kv_total} not divisible by {head_total}."
+            )
+        kv_i = num // int(head_total)
+        if kv_i <= 0:
+            raise ValueError(f"Derived KV at rank {idx} non-positive ({kv_i}).")
+        out.append(int(kv_i))
+    if sum(out) != int(kv_total):
+        raise ValueError(f"Derived KV sum {sum(out)} != total {kv_total}.")
+    return out
+
+
+def _validate_qkv_ratio(*, head_splits: Iterable[int], kv_splits: Iterable[int],
+                        head_total: int, kv_total: int) -> None:
+    q = list(head_splits); k = list(kv_splits)
+    if len(q) != len(k):
+        raise ValueError(f"Q/KV lengths differ: {len(q)} vs {len(k)}.")
+    for idx, (q_i, kv_i) in enumerate(zip(q, k)):
+        if int(q_i) * int(kv_total) != int(kv_i) * int(head_total):
+            raise ValueError(
+                f"Q/KV ratio mismatch at rank {idx}: q={q_i}, kv={kv_i}, "
+                f"global={head_total}:{kv_total}."
+            )
+
+
+def read_tp_splits_from_env(
+    *,
+    tp_size: int,
+    head_total: int,
+    ffn_total: int,
+    kv_total: int,
+    head_granularity: int = 1,
+    ffn_granularity: int = 1,
+) -> tuple[list[int] | None, list[int] | None, list[int] | None]:
+    """Read optional TP split configs from env and validate.
+
+    Returns (head_splits, ffn_splits, kv_splits), each None if unset/empty.
+    Raises ValueError on malformed input.
+    """
+    head_raw = os.environ.get("VLLM_TP_HEAD_SPLITS", "").strip()
+    ffn_raw = os.environ.get("VLLM_TP_FFN_SPLITS", "").strip()
+    kv_raw = os.environ.get("VLLM_TP_KV_SPLITS", "").strip()
+
+    head_splits = parse_and_validate_splits(
+        head_raw, expected_len=tp_size, total=head_total,
+        granularity=head_granularity, name="VLLM_TP_HEAD_SPLITS"
+    ) if head_raw else None
+
+    ffn_splits = parse_and_validate_splits(
+        ffn_raw, expected_len=tp_size, total=ffn_total,
+        granularity=ffn_granularity, name="VLLM_TP_FFN_SPLITS"
+    ) if ffn_raw else None
+
+    kv_splits = parse_and_validate_splits(
+        kv_raw, expected_len=tp_size, total=kv_total,
+        granularity=1, name="VLLM_TP_KV_SPLITS"
+    ) if kv_raw else None
+
+    if head_splits is not None and kv_splits is None:
+        kv_splits = _derive_kv_splits_from_heads(
+            head_splits=head_splits, head_total=head_total, kv_total=kv_total
+        )
+    elif head_splits is None and kv_splits is not None:
+        if head_total % tp_size != 0:
+            raise ValueError(
+                "VLLM_TP_KV_SPLITS is set but uniform head split is impossible "
+                f"(num_attention_heads={head_total}, tp={tp_size}). "
+                "Set VLLM_TP_HEAD_SPLITS together."
+            )
+        uniform_heads = [head_total // tp_size for _ in range(tp_size)]
+        _validate_qkv_ratio(head_splits=uniform_heads, kv_splits=kv_splits,
+                            head_total=head_total, kv_total=kv_total)
+    elif head_splits is not None and kv_splits is not None:
+        _validate_qkv_ratio(head_splits=head_splits, kv_splits=kv_splits,
+                            head_total=head_total, kv_total=kv_total)
+
+    return head_splits, ffn_splits, kv_splits
+
+
+def is_uniform(splits: Iterable[int] | None) -> bool:
+    """Return True if splits is None or all entries equal (i.e. effectively
+    uniform). Used by patched code to fast-path the uniform branch."""
+    if splits is None:
+        return True
+    arr = list(splits)
+    return len(arr) == 0 or len(set(arr)) == 1
